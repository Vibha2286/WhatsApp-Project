const axios = require("axios");
const { saveToken, isTokenExpired, getToken } = require("../utils/token-store");

/**
 * Validate required environment variables at startup
 */
if (
    !process.env.PHONE_NUMBER_ID ||
    !process.env.ACCESS_TOKEN ||
    !process.env.APP_ID ||
    !process.env.APP_SECRET
) {
    throw new Error(
        "Missing required WhatsApp environment variables: PHONE_NUMBER_ID, ACCESS_TOKEN, APP_ID, APP_SECRET"
    );
}

/**
 * Format date as YYYY-MM-DD
 */
function formatDate(date) {
    return date.toISOString().split("T")[0];
}

/**
 * Validate phone number
 */
function validatePhoneNumber(to) {
    if (!/^\d{10,15}$/.test(to)) {
        throw new Error("Invalid phone number format.");
    }
}

/**
 * Get long-lived token from Meta
 */
async function getLongLivedToken() {
    try {
        const response = await axios.get(
            "https://graph.facebook.com/v24.0/oauth/access_token",
            {
                params: {
                    grant_type: "fb_exchange_token",
                    client_id: process.env.APP_ID,
                    client_secret: process.env.APP_SECRET,
                    fb_exchange_token: process.env.ACCESS_TOKEN,
                },
                timeout: 60000,
            }
        );

        const token = response.data.access_token;
        const expiresIn = response.data.expires_in;
        const created = new Date();
        const renew = new Date(created.getTime() + expiresIn * 1000);

        return {
            access_token: token,
            createdAt: formatDate(created),
            renewAt: formatDate(renew),
        };
    } catch (error) {
        console.error(
            "Error fetching long-lived token:",
            JSON.stringify(error.response?.data || error.message, null, 2)
        );
        throw new Error("Failed to get long-lived token");
    }
}

async function isTokenValid(token) {
    try {
        await axios.get("https://graph.facebook.com/v24.0/me", {
            params: { access_token: token },
            timeout: 5000
        });
        return true;
    } catch (err) {
        return false;
    }
}

async function ensureToken(forceRefresh = false) {
    let tokenData = getToken();
    let valid = false;

    if (tokenData?.access_token) {
        valid = await isTokenValid(tokenData.access_token);
    }
    if (forceRefresh || !tokenData || !valid) {
        tokenData = await getLongLivedToken();
        saveToken(tokenData);
        process.env.ACCESS_TOKEN = tokenData.access_token;
    } else {
        process.env.ACCESS_TOKEN = tokenData.access_token;
    }
    return process.env.ACCESS_TOKEN;
}


async function sendRequest(payload) {
    const url = `https://graph.facebook.com/v24.0/${process.env.PHONE_NUMBER_ID}/messages`;

    let attempt = 0;
    const maxRetries = 3;

    // ✅ Get token ONCE
    let token = await ensureToken(false);

    while (attempt < maxRetries) {
        try {
            const response = await axios.post(url, payload, {
                timeout: 60000,
                headers: {
                    Authorization: `Bearer ${token}`,
                    "Content-Type": "application/json",
                },
            });

            return response.data;

        } catch (error) {
            attempt++;

            const apiError = error.response?.data?.error;

            console.error(`Attempt ${attempt} failed`);

            //  Retry only for server errors
            if (
                attempt < maxRetries &&
                (error.response?.status >= 500 || apiError?.code === 131000)
            ) {
                console.log("Retrying request...");
                await new Promise(res => setTimeout(res, 1000 * attempt));
                continue;
            }

            //  Token expired → refresh ONLY once
            if (apiError?.code === 190 && attempt < maxRetries) {
                console.log("Refreshing token...");
                token = await ensureToken(true); // update token
                continue;
            }

            console.error("========== WHATSAPP API ERROR ==========");

            if (error.response) {
                console.error("Status:", error.response.status);
                console.error("Data:", JSON.stringify(error.response.data, null, 2));
            } else {
                console.error("Error Message:", error.message);
            }

            console.error("========================================");

            throw new Error(
                apiError?.message || "WhatsApp message sending failed"
            );
        }
    }
}


/**
 * Send Text Message
 */
async function sendText(to, message) {
    validatePhoneNumber(to);

    if (!message || message.length > 4096) {
        throw new Error("Invalid message content.");
    }

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "text",
        text: { body: message },
    });
}

/**
 * Send Numbered List as Text
 */
async function sendNumberedList(to, message, rows = []) {
    validatePhoneNumber(to);

    if (!Array.isArray(rows) || rows.length === 0) {
        throw new Error("Rows must be a non-empty array.");
    }

    const listText = rows
        .map((r, index) => `${index + 1}. ${r.title}`)
        .join("\n");

    const finalMessage = `${message}\n\n${listText}`;

    return sendText(to, finalMessage);
}

/**
 * Send Interactive Month List
 */
async function sendHalfMonths(to, months = [], year) {
    validatePhoneNumber(to);

    if (!Array.isArray(months) || months.length === 0 || !year) {
        throw new Error("Invalid months or year.");
    }

    const rows = months.map((m) => ({
        id: `${m}_${year}`,
        title: `${m.charAt(0).toUpperCase() + m.slice(1).toLowerCase()}, ${year}`,
    }));

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "list",
            body: { text: "Select the month:" },
            action: {
                button: "Choose Month",
                sections: [{ title: "Months", rows }],
            },
        },
    });
}

/**
 * Send Confirmation Buttons
 */
async function sendConfirmationButtons(to) {
    validatePhoneNumber(to);

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "button",
            body: { text: "Do you want to navigate to the main menu?" },
            action: {
                buttons: [
                    {
                        type: "reply",
                        reply: { id: "YES_CONTINUE", title: "Yes" },
                    },
                    {
                        type: "reply",
                        reply: { id: "CANCEL_CHAT", title: "Cancel" },
                    },
                ],
            },
        },
    });
}

/**
 * Send Year List
 */
async function sendYearList(to) {
    validatePhoneNumber(to);

    const startYear = 2020;
    const currentYear = new Date().getFullYear();

    const years = [];
    for (let y = currentYear; y >= startYear; y--) {
        years.push(y);
    }

    const rows = years.map((y) => ({
        id: y.toString(),
        title: y.toString(),
    }));

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "list",
            body: { text: "Select the year:" },
            action: {
                button: "Choose Year",
                sections: [
                    {
                        title: "Years",
                        rows,
                    },
                ],
            },
        },
    });
}

/**
 * Send Month Range List (H1 / H2)
 */
async function sendMonthRangeList(to) {
    validatePhoneNumber(to);

    const rows = [
        { id: "H1", title: "January - June" },
        { id: "H2", title: "July - December" },
    ];

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "list",
            body: { text: "Select month range:" },
            action: {
                button: "Choose Range",
                sections: [{ title: "Month Range", rows }],
            },
        },
    });
}

/**
 * Send Custom Buttons
 */
async function sendButtons(to, bodyText, buttons = []) {
    validatePhoneNumber(to);

    if (!bodyText || !Array.isArray(buttons) || buttons.length === 0) {
        throw new Error("Body text and buttons are required.");
    }

    if (buttons.length > 3) {
        throw new Error("WhatsApp allows maximum 3 buttons.");
    }

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "button",
            body: { text: bodyText },
            action: {
                buttons: buttons.map((btn) => ({
                    type: "reply",
                    reply: {
                        id: btn.id,
                        title: btn.title,
                    },
                })),
            },
        },
    });
}

module.exports = {
    sendText,
    sendNumberedList,
    sendHalfMonths,
    sendConfirmationButtons,
    sendYearList,
    sendMonthRangeList,
    sendButtons,
    getLongLivedToken,
    ensureToken,
};