/**
 * Send Custom Buttons
 */
async function sendButtons(to, bodyText, buttons = []) {
    validatePhoneNumber(to);

    if (!bodyText || buttons.length === 0) {
        throw new Error("Body text and buttons are required.");
    }

    if (buttons.length > 3) {
        throw new Error("WhatsApp allows maximum 3 buttons.");
    }

    return sendRequest({
        messaging_product: "whatsapp",
        to,
        type: "interactive",
        interactive: {
            type: "button",
            body: { text: bodyText },
            action: {
                buttons: buttons.map(btn => ({
                    type: "reply",
                    reply: {
                        id: btn.id,
                        title: btn.title
                    }
                }))
            }
        }
    });
}

function formatDate(date) {
    return date.toISOString().split("T")[0];
}

async function getLongLivedToken() {
    try {
        const response = await axios.get(
            "https://graph.facebook.com/v24.0/oauth/access_token",
            {
                params: {
                    grant_type: "fb_exchange_token",
                    client_id: process.env.APP_ID,
                    client_secret: process.env.APP_SECRET,
                    fb_exchange_token: process.env.ACCESS_TOKEN
                }
            }
        );

        const token = response.data.access_token;
        const expiresIn = response.data.expires_in; // seconds

        console.log("Long-lived token obtained");

        const created = new Date();
        const renew = new Date(created.getTime() + expiresIn * 1000);

        return {
            access_token: token,
            createdAt: formatDate(created),
            renewAt: formatDate(renew)
        };

    } catch (error) {
        console.error(
            "Error fetching long-lived token:",
            error.response?.data || error.message
        );
        throw new Error("Failed to get long-lived token");
    }
}

async function ensureToken() {
    let tokenData = getToken();
    console.log("Token data loaded:", tokenData);

    if (!tokenData || isTokenExpired(tokenData)) {

        console.log("Token expired or not found. Refreshing...");

        tokenData = await getLongLivedToken();

        saveToken(tokenData);

        process.env.ACCESS_TOKEN = tokenData.access_token;

        console.log("Token refreshed and saved!");

    } else {

        console.log("Token still valid. Using existing token.");
        process.env.ACCESS_TOKEN = tokenData.access_token;

    }

    return tokenData.access_token;
}

module.exports = {
    sendText,
    sendNumberedList,
    sendHalfMonths,
    sendConfirmationButtons,
    sendYearList,
    sendMonthRangeList,
    sendButtons,
    getLongLivedToken,
    ensureToken
};